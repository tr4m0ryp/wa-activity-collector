{
  "name": "wa-activity-collector",
  "version": "0.1.0",
  "description": "Multi-account WhatsApp presence/RTT collector — raw data only, no labelling, no classification",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node --import tsx/esm src/index.ts",
    "dev": "node --import tsx/esm --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^11.5.0",
    "express": "^5.0.1",
    "pino": "^10.1.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
